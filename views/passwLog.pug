//Called from /login
doctype html
html
nav.navbar.navbar-inverse
    .container-fluid
        .navbar-header
        p.nav.navbar-nav
            a(href='/')
                img(src='/images/1FirstPassLogo.png', alt='1FirstPass', heigth='auto', width='130')
            colspan.nav
                a(href='/') Home   
            colspan.nav
                a(href='/aboutUs') About us   
            colspan.nav
                a(href='/contactUs') Contact us
head
Title User to provide a login password
link(rel='stylesheet', href='/stylesheets/main.css')
script(src='/scripts/handleLogin.js' nonce=nonce)
body
  script(nonce=nonce).
        var sid=localStorage.getItem('sessionId');
        console.log('sid: ', sid);
        document.addEventListener('DOMContentLoaded', function() {
           document.getElementById('sid').value = sid;
           //document.getElementById('logCount').value= count;
        });
  .contentarea
  h1 User login password is required and you have #{attempt} attempts to login.
  p 
        form(action='/logPasswHdlr', id='loginForm', method='post') 
                br
                label(for='name') #{username}, please input valid password
                input#name(type='hidden',  name='username', value=`${username}`)
                br
                br
                label(for='passw') Password: (8-16 characters) 
                br
                input#passw(type='password' autofocus, name='loginPassword' required, minlength='8', maxlength='16', value='')
                br
                br
                button(type='submit') Submit
                input#sid(type='hidden', name='sessionId')
                input#logCount(type='hidden', name='logCount', value=`${attempt}`)
br
br
