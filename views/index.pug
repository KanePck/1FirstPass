//extends layout
doctype html
html
	nav.navbar.navbar-inverse
	.container-fluid
		.navbar-header
		p.nav.navbar-nav
			a(href='/')
				img(src='/images/1FirstPassLogo.png', alt='1FirstPass', heigth='auto', width='130')
			colspan.nav
				a(href='/') Home   
			colspan.nav
				a(href='/aboutUs') About us   
			colspan.nav
				a(href='/contactUs') Contact us   
		
	head
		title 1FirstPass 
		link(rel='stylesheet', href='/stylesheets/main.css')
		
	body
		script(nonce=nonce).
			var sid='#{sessObj.sessionId}';
			var time='#{sessObj.timestamp}';
			var login='#{sessObj.login}';
			var uuid='#{uuidObj.uuid}';
			sessionStorage.setItem('sessionId', sid);
			sessionStorage.setItem('uuid', uuid);
			localStorage.setItem('timestamp', time);
			localStorage.setItem('login', login);
			console.log('session Id: ', sessionStorage.getItem('sessionId'));
			console.log('uuid: ', sessionStorage.getItem('uuid'));
		h1#3d Welcome to 1FirstPass website
		p.box#mission How we can serve you:
			ul
				li.list We help you to generate strong password for any web page without having to remember those passwords.
				li.list Now you only are required to remember one master password or have your face photographed as authorization and access to our web site and we do the rest for you.
				br
				li.list Your master password to 1FirstPass are not stored on our server but are encrypted to private and public keys pair, which are used to identify the correct passwor>
				li.list 2FA is additional security that an OTP is sent to your email after logging in for account authentication.
				li.list So you can be certain of very high security of your master password and your account.
				br
				li.list The private key is used to encrypt Data Encryption Key(DEK) which later is used to encrypt your web/app secured passwords on our server.
				li.list So the secured passwords are very secured due to double encryption.
				li.list In case you want to store your old passwords generated by yourself, you can do so.
				br
				li.list Now, on your pc or laptop, www.1firstpass.com works on all browsers.
				li.list In case you lose your master password, you can use our Recovery Key, that is provided at the time of signin up, to unlock the stored web credentials, which you c>
				li.list 1FirstPass now also works on android devices(phone, tablet) and ios devices (IPhone, IPad, macBook).
				br
				li.list 1FirstPass has been rated A+ security from Mozilla organization based on HTTP Observatory Report scan https://developer.mozilla.org/en-US/observatory
				li.list So www.1firstpass.com can be your ultimate management and security of all your website credentials.
		p#user Login or Register
			form(action='/login', method='post') Existing User, please login.
				br
				br
				label(for='uname')
				input#uname(type='text' autofocus, name='username' placeholder='Your name' required)
				br
				br
				p If you signed up with self photo login option, please check box if require this option.
				label(for='face') Face photo login
				input#face(type='checkbox', name='faceOption', value='yes')
				br
				br
				div
				button(type='submit') Login 
				br
				br
				br
		p Sign up
			form(action='/signup', id='signUp', method='post') New User, please sign up
				br
				br
				label(for='uname') User Name: 
				br
				input#uname(type='text', name='username' required, minlength='4', maxlength='10', value='Your name')
				br
				br
				label(for='email') Email: 
				br
				input#email(type='email', name='email' required, placeholder='Email address')
				br
				br
				label(for='phone') Phone No: Please enter international format "CountryCodePhoneNo"
				br
				input#phone(type='tel', name='phone', placeholder = "Countrycode+PhoneNo", pattern="^\[1-9]\d{1,14}$", 
				            title='Enter phone number in international format, e.g. 66891234567', required)
				br
				br
				button(type='submit') Sign up
	br
	br
	footer
		p The entirety of this site is protected by copyright @2024 1FirstPass company limited
		address 84/23 Ratchapruek28 Road, Talingchan, Bangkok 10170, Thailand
		p
		colspan 
			a(href='/tnc') Terms&Conditions  
		colspan 
			a(href='/privPo') Privacy Policy